# ============================================================
#  Admon Project — Variables de Entorno
#  Copia este archivo como ".env" y rellena los valores reales.
#  NUNCA subas el archivo .env a control de versiones (Git).
# ============================================================

# ── Base de Datos MySQL ──────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=TU_PASSWORD_AQUI
DB_NAME=admon_project

# ── SMTP (Correo de envío de campañas y recuperación) ────────
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password-de-16-caracteres

# ── Servidor de Tracking ─────────────────────────────────────
# URL base donde corre tracking_server.py
TRACKING_URL=http://localhost:8081
